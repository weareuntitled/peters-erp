# Auto detect text files
* text=auto

# Force shell scripts to use LF line endings
*.sh text eol=lf

# Force config files to use LF
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.json text eol=lf

# Prevent binary files from being modified
*.png binary
*.jpg binary
*.jpeg binary
*.svg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
*.sqlite3 binary
