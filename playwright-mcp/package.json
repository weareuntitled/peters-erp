{
  "name": "gswin-erp-playwright-mcp",
  "version": "1.0.0",
  "description": "Playwright MCP automation for GSWIN ERP system",
  "scripts": {
    "start-mcp": "npx @playwright/mcp@latest --browser chrome",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright test --reporter=html",
    "automate:inventory": "node scripts/automate-inventory.js",
    "automate:orders": "node scripts/automate-orders.js",
    "automate:reports": "node scripts/automate-reports.js"
  },
  "dependencies": {
    "@playwright/mcp": "^0.0.71",
    "@playwright/test": "^1.40.0",
    "dotenv": "^16.0.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
